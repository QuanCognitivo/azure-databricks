# Local variable files (may contain secrets)
terraform.tfvars
*.auto.tfvars

# Backend config (contains storage account name — generated by scripts/bootstrap-state.sh)
backend.hcl

# Terraform working directory
.terraform/
.terraform.lock.hcl

# State files
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
